#!/usr/bin/env bash
set -euo pipefail

env_file="${EXA_MCP_ENV_FILE:-${HOME}/.codex/mcp/exa-mcp.env}"

if [[ -z "${EXA_API_KEY:-}" && -f "${env_file}" ]]; then
  set -a
  source "${env_file}"
  set +a
fi

if [[ -z "${EXA_API_KEY:-}" ]]; then
  echo "EXA_API_KEY is not set. Add it to ${env_file} or export it before starting Codex." >&2
  exit 1
fi

if command -v npx >/dev/null 2>&1; then
  exec npx -y exa-mcp-server
fi

for npx_bin in \
  "${HOME}"/.nvm/versions/node/*/bin/npx \
  /opt/homebrew/bin/npx \
  /usr/local/bin/npx; do
  if [[ -x "${npx_bin}" ]]; then
    exec "${npx_bin}" -y exa-mcp-server
  fi
done

echo "npx was not found. Install Node.js/npm and restart Codex." >&2
exit 1
