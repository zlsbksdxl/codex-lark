{
  "name": "codex-plugins",
  "interface": {
    "displayName": "Codex Plugins"
  },
  "plugins": [
    {
      "name": "exa",
      "displayName": "Exa Web Search",
      "source": {
        "source": "local",
        "path": "./plugins/exa"
      },
      "policy": {
        "installation": "AVAILABLE",
        "authentication": "ON_INSTALL"
      },
      "category": "Productivity",
      "description": "Search and fetch current web sources through Exa with browser OAuth.",
      "icon": "./plugins/exa/assets/logo.svg"
    },
    {
      "name": "feishu2codex",
      "displayName": "Feishu to Codex",
      "source": {
        "source": "local",
        "path": "./plugins/feishu2codex"
      },
      "policy": {
        "installation": "AVAILABLE",
        "authentication": "ON_USE"
      },
      "category": "Productivity",
      "description": "Install, connect, and use Feishu/Lark through the official lark-cli workflows.",
      "icon": "./plugins/feishu2codex/assets/logo.svg"
    }
  ]
}
